<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kalkulator Jatah Hidup Harian"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih Periode Keuangan:"
        android:textStyle="bold"/>

    <RadioGroup
        android:id="@+id/radioGroupPeriode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/radioBulanan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bulanan (30 Hari)"
            android:checked="true"/> <RadioButton
        android:id="@+id/radioMingguan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mingguan (7 Hari)"
        android:layout_marginStart="16dp"/>
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Total Uang / Gaji (Rp):" />
    <EditText
        android:id="@+id/inputGaji"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="Contoh: 5000000"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Biaya Tetap (Kos, Bensin, Kuota, dll):" />
    <EditText
        android:id="@+id/inputBiayaTetap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="Isi 0 jika tidak ada" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="*Note: Beri nilai 0 jika tidak menanggung biaya kos atau tanggungan tetap lainnya."
        android:textSize="12sp"
        android:textColor="#808080"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3. Target Tabungan (Rp):" />
    <EditText
        android:id="@+id/inputTabungan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="Isi 0 jika tidak menabung"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnHitung"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hitung Jatah Harian"
        android:onClick="hitungJatahHarian" />

    <TextView
        android:id="@+id/textHasil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textColor="#006400"
        android:text="Hasil perhitungan akan muncul di sini"/>

</LinearLayout>