<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#E2E8F0"
    android:gravity="center"
    tools:context=".ProfileActivity">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#0F172A">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STUDENT ID"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:textColor="#10B981"
                android:layout_marginBottom="32dp" />

            <TextView
                android:id="@+id/tvProfilNama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp"
                tools:text="Nama: Aditias Zulmatoriq" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvProfilNim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#CBD5E1"
                android:layout_marginBottom="16dp"
                tools:text="NIM: F1D02310031" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvProfilProdi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#CBD5E1"
                android:layout_marginBottom="16dp"
                tools:text="Program Studi: Teknik Informatika" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvProfilGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#CBD5E1"
                android:layout_marginBottom="16dp"
                tools:text="Jenis Kelamin: Laki-laki" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvProfilHobi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#CBD5E1"
                tools:text="Hobi: Coding, Bermain Game" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>